generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// —— Next-Auth requeridos ————————————————————————————————————

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// —— Usuario ————————————————————————————————————————————————

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // Límite de 1 imagen de prueba gratuita por Google ID
  previewUsado Boolean @default(false)
  previewUrl   String? // URL de la imagen de prueba (con marca de agua)

  createdAt DateTime @default(now())

  accounts Account[]
  sessions Session[]
  pedidos  Pedido[]
}

// —— Pedido ————————————————————————————————————————————————

model Pedido {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Configuración — Interior
  tamano                Tamano
  tematicas             String[]
  tematicasPersonalizadas String[] @default([])
  estilos               Estilo[]
  tipoPapel             TipoPapel @default(BLANCO)
  fotoFamiliarKey       String?
  // Situaciones puntuales cargadas por el admin para este pedido, por temática
  // (ej. {"River Plate": ["el nene con la camiseta en el Monumental", "..."]})
  // — se usan en vez de las genéricas/predefinidas cuando están cargadas.
  situacionesPorTematica Json?

  // Configuración — Tapa
  tituloTapa        String?
  subtituloTapa     String?
  observacionesTapa String?
  imagenTapaKey     String?
  dedicatoria       String?
  estiloTapa        Estilo?

  // Estado del pedido
  estado EstadoPedido @default(ESPERANDO_PAGO)

  // Datos de envío
  nombreCompleto     String
  direccion          String
  codigoPostal       String
  localidad          String
  provincia          String
  telefono           String
  emailEnvio         String
  tipoEntrega        TipoEntrega @default(DOMICILIO)
  costoEnvioEstimado Int? // estimado por zona mostrado al cliente — MiCorreo aún no dio acceso a la API, se confirma el costo real por WhatsApp/email antes de despachar

  // Pago
  medioPago              MedioPago @default(MERCADOPAGO)
  mpPreferenceId         String?
  mpPaymentId            String?
  pagadoAt               DateTime?
  cuponCodigo            String? // snapshot del código usado (el Cupon puede editarse/desactivarse después)
  cuponDescuentoPorcentaje Int?  // snapshot del % aplicado al momento del pedido

  // PDF y aprobación
  pdfUrl        String?
  pdfSubidoAt   DateTime?
  clienteAprobo Boolean   @default(false)
  aprobadoAt    DateTime?

  // Despacho
  trackingNumero String?
  despachadoAt   DateTime?

  // Limpieza automática a 30 días
  eliminarAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  imagenes ImagenPedido[]
  fotos    FotoCliente[]
}

// —— Registro de compradores (sobrevive al borrado de un pedido) ————————
// Al eliminar un pedido de prueba desde el admin se borran el pedido, sus fotos,
// imágenes y PDFs — pero se guarda antes un snapshot de los datos del comprador acá.

model CompradorHistorial {
  id               String   @id @default(cuid())
  pedidoIdOriginal String
  nombreCompleto   String
  email            String
  telefono         String
  direccion        String
  codigoPostal     String
  localidad        String
  provincia        String
  tamano           Tamano
  tematicas        String[]
  medioPago        MedioPago
  montoARS         Int?
  pedidoCreadoEn   DateTime
  eliminadoEn      DateTime @default(now())
}

// —— Cupones de descuento (para promos/influencers) ————————————————

model Cupon {
  id                  String   @id @default(cuid())
  codigo              String   @unique
  descuentoPorcentaje Int      @default(100)
  activo              Boolean  @default(true)
  usosMaximos         Int? // null = sin límite
  usosActuales        Int      @default(0)
  nota                String? // uso interno, ej. "Regalo influencer Fulanita"

  createdAt DateTime @default(now())
}

// —— Plantillas de mensajes al cliente (editables desde el admin) ————————

model PlantillaMensaje {
  id        String   @id @default(cuid())
  clave     String   @unique // identifica la instancia del proceso, ej. "DESPACHO"
  nombre    String // etiqueta legible para el panel admin
  asunto    String? // para cuando se mande por email
  cuerpo    String   @db.Text // con variables tipo {{nombre}}

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// —— Fotos del cliente (input) ————————————————————————————————

model FotoCliente {
  id       String @id @default(cuid())
  pedidoId String
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  url          String
  orden        Int
  seleccionada Boolean @default(true) // si está destildada, no se usa para generar ilustraciones

  createdAt DateTime @default(now())
}

// —— Imágenes generadas (output) ——————————————————————————————

model ImagenPedido {
  id       String @id @default(cuid())
  pedidoId String
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  orden       Int
  tipo        TipoImagen
  url         String?
  promptUsado String?    @db.Text
  promptExtra String?    @db.Text // instrucciones puntuales que carga el admin antes de generar/regenerar esta imagen
  aprobada    Boolean    @default(false)

  createdAt DateTime @default(now())
}

// —— Enums ————————————————————————————————————————————————————

enum Tamano {
  CHICO
  GRANDE
}

enum Estilo {
  REALISTA
  PIXAR
  ANIME
  GHIBLI
}

enum TipoPapel {
  BLANCO
  AHUESADO
  COMBINADO
}

enum TipoEntrega {
  SUCURSAL
  DOMICILIO
}

enum MedioPago {
  MERCADOPAGO
  TRANSFERENCIA
}

enum TipoImagen {
  A
  B
  C
  TAPA
  RETIRACION_TAPA
  CONTRATAPA
  RETIRACION_CONTRATAPA
}

enum EstadoPedido {
  ESPERANDO_PAGO
  ESPERANDO_GENERACION
  EN_REVISION
  ESPERANDO_APROBACION
  APROBADO
  EN_IMPOSICION
  IMPRIMIENDO
  ENVIADO
}
