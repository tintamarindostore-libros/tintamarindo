# ─────────────────────────────────────────────
# TINTAMORA — Variables de entorno
# Copiá este archivo como .env.local para desarrollo
# o cargá estas variables en Vercel para producción
# ─────────────────────────────────────────────

# ── Base de datos ──────────────────────────────
# PostgreSQL — formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://usuario:contraseña@host:5432/colorear-kids

# ── Autenticación (next-auth v5) ───────────────
# Generá AUTH_SECRET con: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://tintamarindo.com

# Google OAuth — conseguí las credenciales en console.cloud.google.com
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Almacenamiento (Cloudflare R2) ─────────────
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tintamarindo

# ── Generación de imágenes (OpenAI) ───────────
OPENAI_API_KEY=sk-...

# ── Emails (Resend) ────────────────────────────
# Creá la API Key en resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM=Tintamarindo <no-reply@tintamarindo.com>

# ── Pagos (MercadoPago) ────────────────────────
# Conseguí estas credenciales en mercadopago.com/developers
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ── Envíos (Correo Argentino — MiCorreo) ──────
# Credenciales de la cuenta MiCorreo del negocio
MICORREO_USER=
MICORREO_PASSWORD=

# ── Sitio ──────────────────────────────────────
# URL pública del sitio (sin barra al final)
NEXT_PUBLIC_SITE_URL=https://tintamarindo.com

# ── Admin ──────────────────────────────────────
# Email de la cuenta de Google del administrador
ADMIN_EMAIL=cordiatec@gmail.com
